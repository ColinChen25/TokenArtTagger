<Window x:Class="TokenArtTagger.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:TokenArtTagger.App.ViewModels"
        mc:Ignorable="d"
        Title="{Binding AppTitle}" Height="860" MinHeight="680" Width="1380" MinWidth="1060"
        Background="#F4F3EF"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#252525" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="4,0,0,0" />
        </Style>
        <Style x:Key="TagButton" TargetType="Button">
            <Setter Property="MinWidth" Value="78" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="AllowDrop" Value="True" />
            <EventSetter Event="Drop" Handler="TagButton_Drop" />
            <EventSetter Event="PreviewDragOver" Handler="TagButton_PreviewDragOver" />
        </Style>
        <Style x:Key="BucketButton" TargetType="Button" BasedOn="{StaticResource TagButton}">
            <Setter Property="MinWidth" Value="92" />
            <Setter Property="MinHeight" Value="34" />
        </Style>
        <Style x:Key="TileItem" TargetType="ListBoxItem">
            <Setter Property="Width" Value="178" />
            <Setter Property="Height" Value="230" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>
        <DataTemplate x:Key="ImageTileTemplate" DataType="{x:Type vm:ImageItemViewModel}">
            <Border Background="#FAFAF7" CornerRadius="6" Padding="8"
                    MouseRightButtonUp="ImageTile_RightClick"
                    ToolTip="{Binding TagIssueMessage}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="#DDD7CE" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasIncompleteTags}" Value="True">
                                <Setter Property="BorderBrush" Value="#B7791F" />
                                <Setter Property="BorderThickness" Value="2" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasInvalidTags}" Value="True">
                                <Setter Property="BorderBrush" Value="#B42318" />
                                <Setter Property="BorderThickness" Value="2" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="122" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#E8E5DE" CornerRadius="4">
                        <Image Source="{Binding Thumbnail}" Stretch="Uniform" Loaded="ThumbnailImage_Loaded" />
                    </Border>
                    <TextBlock Grid.Row="1" Margin="0,7,0,0" Text="{Binding DisplayName}" TextWrapping="Wrap"
                               FontWeight="SemiBold" MaxHeight="42" ToolTip="{Binding DisplayName}" />
                    <TextBlock Grid.Row="2" Margin="0,4,0,0" Text="{Binding FileName}" TextTrimming="CharacterEllipsis"
                               Foreground="#666666" ToolTip="{Binding FullPath}" />
                    <TextBlock Grid.Row="3" Margin="0,4,0,0" Text="{Binding ProposedFileName}" TextWrapping="Wrap"
                               Foreground="#245C37" MaxHeight="34" />
                    <StackPanel Grid.Row="4" Orientation="Vertical" Margin="0,4,0,0">
                        <DockPanel>
                            <TextBlock Text="!" Foreground="#B42318" FontWeight="Bold" Margin="0,0,6,0"
                                       ToolTip="{Binding TagIssueMessage}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasRenameBlockingIssue}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="Changed" Foreground="#8A4D00" FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDirty}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DockPanel>
                        <TextBlock Text="{Binding PreviewError}" Foreground="#9C1F1F" TextWrapping="Wrap" MaxHeight="34" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
        <Style x:Key="StatusBorder" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D7D3CA" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsStatusWarning}" Value="True">
                    <Setter Property="Background" Value="#FFF1F0" />
                    <Setter Property="BorderBrush" Value="#B42318" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Style="{StaticResource ToolButton}" Margin="0,0,8,0"
                    Content="Choose Folder"
                    Command="{Binding BrowseCommand}" />
            <TextBox Grid.Column="1" MinHeight="32" VerticalContentAlignment="Center"
                     Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}" />
            <TextBox Grid.Column="2" MinHeight="32" Margin="8,0,0,0" VerticalContentAlignment="Center"
                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" />
            <StackPanel Grid.Column="3" Orientation="Horizontal">
                <Button Style="{StaticResource ToolButton}" Content="Scan Folder" Command="{Binding ScanCommand}" />
                <Button Style="{StaticResource ToolButton}" Content="Preview Selected" Command="{Binding PreviewRenameCommand}" />
                <Button Style="{StaticResource ToolButton}" Content="Preview Changed" Command="{Binding PreviewChangedCommand}" />
                <Button Style="{StaticResource ToolButton}" Content="Cancel Preview" Command="{Binding CancelPreviewCommand}" />
                <Button Style="{StaticResource ToolButton}" Content="Rename Selected" Command="{Binding RenameSelectedCommand}"
                        ToolTip="{Binding RenameBlockReason}" />
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="1">
            <TabItem Header="Library">
                <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="250" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="330" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#D7D3CA" BorderThickness="1" CornerRadius="6" Padding="12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Tags" Style="{StaticResource PanelTitle}" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding TagButtonsView}">
                                    <ItemsControl.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.ContainerStyle>
                                                <Style TargetType="{x:Type GroupItem}">
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="{x:Type GroupItem}">
                                                                <GroupBox Header="{Binding Name}" Margin="0,0,0,10" Padding="8">
                                                                    <ItemsPresenter />
                                                                </GroupBox>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </GroupStyle.ContainerStyle>
                                            <GroupStyle.Panel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </GroupStyle.Panel>
                                        </GroupStyle>
                                    </ItemsControl.GroupStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type vm:TagButtonViewModel}">
                                            <Button Style="{StaticResource TagButton}"
                                                    Command="{Binding DataContext.ApplyTagCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="{Binding Group}">
                                                <TextBlock Text="{Binding Label}" FontWeight="SemiBold" TextAlignment="Center" />
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Margin="12,0" Background="#FFFFFF" BorderBrush="#D7D3CA" BorderThickness="1" CornerRadius="6" Padding="10">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Images" Style="{StaticResource PanelTitle}" />
                            <ListBox x:Name="LibraryList"
                                     ItemsSource="{Binding ItemsView}"
                                     SelectionMode="Extended"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     SelectionChanged="LibraryList_SelectionChanged"
                                     PreviewMouseLeftButtonDown="ImageList_PreviewMouseLeftButtonDown"
                                     PreviewMouseLeftButtonUp="ImageList_PreviewMouseLeftButtonUp"
                                     MouseMove="ImageList_MouseMove"
                                     KeyDown="LibraryList_KeyDown"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <StaticResource ResourceKey="TileItem" />
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <StaticResource ResourceKey="ImageTileTemplate" />
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#D7D3CA" BorderThickness="1" CornerRadius="6" Padding="12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Selection" Style="{StaticResource PanelTitle}" />
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="{Binding SelectionCountText}" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <StackPanel DataContext="{Binding SelectedItem}">
                                        <TextBlock Text="{Binding FullPath}" TextWrapping="Wrap" FontWeight="SemiBold" />
                                        <Separator Margin="0,12" />
                                        <TextBlock Text="Current filename" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding FileName}" TextWrapping="Wrap" Margin="0,4,0,12" />
                                        <TextBlock Text="Parsed tags" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ParsedTagsText}" TextWrapping="Wrap" Margin="0,4,0,12" />
                                        <TextBlock Text="Current tags" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding CurrentTagsText}" TextWrapping="Wrap" Margin="0,4,0,12" />
                                        <TextBlock Text="Proposed filename" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ProposedFileName}" TextWrapping="Wrap" Margin="0,4,0,12" Foreground="#245C37" />
                                        <TextBlock Text="{Binding PreviewError}" TextWrapping="Wrap" Foreground="#9C1F1F" />
                                    </StackPanel>
                                    <Separator Margin="0,12" />
                                    <WrapPanel Margin="0,0,0,12">
                                        <Button Style="{StaticResource ToolButton}" Margin="0,0,6,6" Content="Clear Selected Temporary Tags" Command="{Binding ClearSelectedTemporaryTagsCommand}" />
                                        <Button Style="{StaticResource ToolButton}" Margin="0,0,6,6" Content="Clear All Temporary Tags" Command="{Binding ClearAllTemporaryTagsCommand}" />
                                    </WrapPanel>
                                    <Separator Margin="0,0,0,12" />
                                    <TextBlock Text="{Binding RenameBlockReason}" TextWrapping="Wrap" Foreground="#555555" />
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Bucket Tagging">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#D7D3CA" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="Pass" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,6,0" />
                            <ComboBox Width="170" VerticalContentAlignment="Center" ItemsSource="{Binding BucketPasses}" SelectedItem="{Binding SelectedBucketPass}" />
                            <TextBlock Text="Filter" VerticalAlignment="Center" FontWeight="SemiBold" Margin="16,0,6,0" />
                            <ComboBox Width="130" VerticalContentAlignment="Center" ItemsSource="{Binding BucketFilterModes}" SelectedItem="{Binding SelectedBucketFilter}" />
                            <TextBlock Text="Page size" VerticalAlignment="Center" FontWeight="SemiBold" Margin="16,0,6,0" />
                            <ComboBox Width="80" VerticalContentAlignment="Center" ItemsSource="{Binding BucketPageSizes}" SelectedItem="{Binding BucketPageSize}" />
                            <Button Style="{StaticResource ToolButton}" Content="Previous" Command="{Binding PreviousBucketPageCommand}" />
                            <TextBlock Text="{Binding BucketPageText}" VerticalAlignment="Center" Margin="10,0" />
                            <Button Style="{StaticResource ToolButton}" Content="Next" Command="{Binding NextBucketPageCommand}" />
                            <TextBlock Text="Default" VerticalAlignment="Center" FontWeight="SemiBold" Margin="16,0,6,0" />
                            <ComboBox Width="130" VerticalContentAlignment="Center" ItemsSource="{Binding BucketBuckets}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding SelectedDefaultBucketValue}" />
                            <Button Style="{StaticResource ToolButton}" Content="Apply default to current page" Command="{Binding ApplyDefaultToPageCommand}" />
                            <Button Style="{StaticResource ToolButton}" Content="Invert Selection" Command="{Binding InvertBucketSelectionCommand}" />
                            <Button Style="{StaticResource ToolButton}" Content="Select Untagged Page" Command="{Binding SelectUntaggedBucketCommand}" />
                        </WrapPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="260" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#D7D3CA" BorderThickness="1" CornerRadius="6" Padding="12">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Buckets" Style="{StaticResource PanelTitle}" />
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding BucketBuckets}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:BucketDefinitionViewModel}">
                                                <Button Style="{StaticResource BucketButton}"
                                                        Command="{Binding DataContext.ApplyBucketCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold" TextAlignment="Center" />
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="1" Margin="12,0" Background="#FFFFFF" BorderBrush="#D7D3CA" BorderThickness="1" CornerRadius="6" Padding="10">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Current Page" Style="{StaticResource PanelTitle}" />
                                <ListBox x:Name="BucketList"
                                         ItemsSource="{Binding BucketPageItems}"
                                         SelectionMode="Extended"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         SelectionChanged="BucketList_SelectionChanged"
                                         PreviewMouseLeftButtonDown="ImageList_PreviewMouseLeftButtonDown"
                                         PreviewMouseLeftButtonUp="ImageList_PreviewMouseLeftButtonUp"
                                         MouseMove="ImageList_MouseMove"
                                         KeyDown="BucketList_KeyDown"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <StaticResource ResourceKey="TileItem" />
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <StaticResource ResourceKey="ImageTileTemplate" />
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#D7D3CA" BorderThickness="1" CornerRadius="6" Padding="12">
                            <StackPanel>
                                <TextBlock Text="Bucket Selection" Style="{StaticResource PanelTitle}" />
                                <TextBlock Text="{Binding BucketSelectionCountText}" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <TextBlock Text="Ctrl+click, Shift+click, arrow keys, Ctrl+A, and Escape work in the current page." TextWrapping="Wrap" Foreground="#555555" />
                                <Separator Margin="0,12" />
                                <TextBlock Text="Partial bucket tags are saved as work-in-progress app data outside the image folder and outside the repository." TextWrapping="Wrap" />
                                <Separator Margin="0,12" />
                                <Button Style="{StaticResource ToolButton}" Margin="0,0,0,6" Content="Clear Selected Temporary Tags" Command="{Binding ClearSelectedTemporaryTagsCommand}" />
                                <Button Style="{StaticResource ToolButton}" Margin="0,0,0,6" Content="Clear Current Bucket Pass Tags" Command="{Binding ClearCurrentBucketPassTagsCommand}" />
                                <Button Style="{StaticResource ToolButton}" Margin="0,0,0,6" Content="Clear All Temporary Tags" Command="{Binding ClearAllTemporaryTagsCommand}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource StatusBorder}" CornerRadius="6" Padding="10">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
